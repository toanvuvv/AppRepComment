# API Key dùng cho authentication (frontend và backend phải khớp nhau)
# Tạo bằng: python -c "import secrets; print(secrets.token_hex(32))"
APP_API_KEY=your-secret-key-here

# Môi trường: development | production
ENV=development

# Database path (mặc định: ./database.db)
DATABASE_URL=sqlite:///./database.db

# Encryption key cho cookies (tạo bằng: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# COOKIE_ENCRYPTION_KEY=your-fernet-key-here
