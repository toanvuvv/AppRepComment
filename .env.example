# ======================================================================
# App Rep Comment — môi trường cho Docker Compose
# Copy file này thành `.env` ở thư mục gốc trước khi chạy `docker compose up`
# ======================================================================

# --- Auth (JWT) ---
# Tạo JWT_SECRET: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_HOURS=8
ADMIN_USERNAME=admin
ADMIN_PASSWORD=121212
# Environment: development | production (production enforces JWT_SECRET)
ENV=development

# Encryption key cho cookies moderator (Fernet).
# Tạo: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=rs_z7htQ8L_22KJQMxc_XtDnCzpwiS-vmFKMw0AAcEE=

# OpenAI key cho AI reply / knowledge reply. Bỏ trống nếu không dùng AI.
OPENAI_API_KEY=

# Cổng public của frontend (nginx). Đổi nếu 8080 bị chiếm.
FRONTEND_PORT=8080

# CORS — mặc định chỉ cho phép origin local. Khi deploy thêm domain thật vào.
CORS_ORIGINS=http://localhost:8080,http://localhost
