# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_HOURS=8
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-login
# Environment: development | production (production requires JWT_SECRET)
ENV=development

DATABASE_URL=sqlite:///./database.db
APP_ENCRYPTION_KEY=change-me-to-a-fernet-key

# OpenAI key for AI reply / knowledge reply. Leave empty to disable AI.
OPENAI_API_KEY=

# CORS — defaults to local dev origin. Add real domain on deploy.
CORS_ORIGINS=http://localhost:5173
